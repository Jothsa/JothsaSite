{
  "name": "quotes",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": " vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --cache --plugin-search-dir . --check . && eslint . && stylelint '**/*.{css,postcss,svelte}'",
    "format": "prettier --cache --plugin-search-dir . --write .; stylelint --fix '**/*.{css,postcss,svelte}'",
    "pb-typegen": "source .env; pocketbase-typegen -u $VITE_PB_URL -e $PB_EMAIL -p $PB_PASSWORD --out ./src/lib/pocketbase-types.ts"
  },
  "devDependencies": {
    "@iconify/icons-material-symbols": "^1.2.30",
    "@iconify/icons-mdi": "^1.2.41",
    "@iconify/icons-ph": "^1.2.3",
    "@iconify/svelte": "^3.1.0",
    "@playwright/test": "^1.31.1",
    "@sveltejs/adapter-auto": "^2.0.0",
    "@sveltejs/kit": "^1.8.3",
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "open-props": "^1.5.5",
    "pocketbase-typegen": "^1.1.4",
    "postcss": "^8.4.21",
    "postcss-html": "^1.5.0",
    "postcss-jit-props": "^1.0.11",
    "postcss-load-config": "^4.0.1",
    "postcss-mixins": "^9.0.4",
    "postcss-preset-env": "^8.0.1",
    "prettier": "^2.8.0",
    "prettier-plugin-svelte": "^2.8.1",
    "stylelint": "^15.2.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-idiomatic-order": "^9.0.0",
    "stylelint-config-standard": "^30.0.1",
    "stylelint-high-performance-animation": "^1.8.0",
    "svelte": "^3.54.0",
    "svelte-check": "^3.0.4",
    "svelte-masonry-jothsa": "^0.0.5",
    "svelte-preprocess": "^5.0.1",
    "tslib": "^2.4.1",
    "typescript": "^4.9.3",
    "vite": "^4.1.4",
    "vite-plugin-stylelint": "^4.2.0"
  },
  "type": "module",
  "dependencies": {
    "@svelteuidev/composables": "^0.10.0",
    "@svelteuidev/core": "^0.10.0",
    "agnostic-svelte": "^1.1.27",
    "modern-normalize": "^1.1.0",
    "pocketbase": "^0.11.1",
    "svelte-preprocess-import-assets": "^0.2.6"
  }
}
