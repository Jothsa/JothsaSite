{
  "name": "quotes",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "./pb/pocketbase serve --http '127.0.0.1:8090' & vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "playwright test",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --plugin-search-dir . --check . && eslint .",
    "format": "prettier --plugin-search-dir . --write .",
    "pb-typegen": "pocketbase-typegen --db ./pb/pb_data/data.db"
  },
  "devDependencies": {
    "@playwright/test": "^1.31.1",
    "@sveltejs/adapter-auto": "^2.0.0",
    "@sveltejs/kit": "^1.8.3",
    "@typescript-eslint/eslint-plugin": "^5.53.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "open-props": "^1.5.5",
    "pocketbase-typegen": "^1.1.4",
    "postcss": "^8.4.21",
    "postcss-jit-props": "^1.0.11",
    "postcss-load-config": "^4.0.1",
    "postcss-preset-env": "^8.0.1",
    "prettier": "^2.8.0",
    "prettier-plugin-svelte": "^2.8.1",
    "svelte": "^3.54.0",
    "svelte-check": "^3.0.4",
    "svelte-masonry-jothsa": "^0.0.5",
    "svelte-preprocess": "^5.0.1",
    "tslib": "^2.4.1",
    "typescript": "^4.9.3",
    "vite": "^4.1.4"
  },
  "type": "module",
  "dependencies": {
    "@svelteuidev/composables": "^0.10.0",
    "@svelteuidev/core": "^0.10.0",
    "modern-normalize": "^1.1.0",
    "pocketbase": "^0.11.1",
    "svelte-preprocess-import-assets": "^0.2.6"
  }
}
