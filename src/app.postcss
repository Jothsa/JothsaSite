  --agnostic-primary-hover-modelight: ;
  --agnostic-primary-modelight: ;
  --agnostic-light-modelight: ;
  --agnostic-dark-modelight: ;
  --agnostic-gray-dark-modelight: ;
  --agnostic-gray-mid-dark-modelight: ;
  --agnostic-gray-mid-modelight: ;
  --agnostic-gray-light-modelight: ;
