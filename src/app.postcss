  --agnostic-warning-light-modedark: ;
  --agnostic-warning-dark-modedark: ;
  --agnostic-secondary-hover-modedark: ;
  --agnostic-secondary-modedark: ;
  --agnostic-primary-light-modedark: #f9f9f9;
  --agnostic-primary-dark-modedark: #121212;
  --agnostic-primary-border-modedark: ;
  --agnostic-primary-hover-modedark: ;
  --agnostic-primary-modedark: ;
  --agnostic-light-modedark: ;
  --agnostic-dark-modedark: ;
  --agnostic-gray-dark-modedark: ;
  --agnostic-gray-mid-dark-modedark: ;
